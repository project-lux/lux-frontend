{
  "name": "lux-frontend-server",
  "version": "0.1.0",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.13.1",
      "onFail": "error"
    }
  },
  "main": "index.ts",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "scripts": {
    "dev-prep": "pnpm clean && mkdir -p build && cp .env* build/ && pnpm copy-client && pnpm compile",
    "dev": "concurrently --kill-others npm:compile-watch npm:nodemon",
    "build": "pnpm clean && pnpm compile && pnpm copy-client",
    "start": "cd build && node -r --enable-source-maps index.js",
    "lint": "eslint . --ext .ts",
    "clean": "rm -rf build",
    "compile": "tsc -sourcemap",
    "compile-watch": "tsc --sourcemap --watch",
    "copy-client": "cp -r ../client/dist build/public",
    "nodemon": "cd build && nodemon -r --enable-source-maps -q index.js"
  },
  "dependencies": {
    "@eslint/compat": "2.1.0",
    "@eslint/eslintrc": "3.3.6",
    "@eslint/js": "10.0.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/cors": "^2.8.12",
    "@types/express": "5.0.6",
    "commander": "15.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "5.2.1",
    "winston": "^3.3.3"
  },
  "devDependencies": {
    "@types/jest": "^29.2.0",
    "@types/node": "^22.20.1",
    "@typescript-eslint/eslint-plugin": "8.63.0",
    "@typescript-eslint/parser": "8.63.0",
    "ast-types": "^0.14.2",
    "astring": "^1.8.1",
    "concurrently": "^7.1.0",
    "eslint": "9.39.4",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.6",
    "jest": "30.4.2",
    "nodemon": "^2.0.15",
    "prettier": "3.8.4",
    "typescript": "5.9.3"
  }
}
