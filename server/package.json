{
  "name": "lux-frontend-server",
  "version": "0.1.0",
  "main": "index.ts",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev-prep": "yarn clean && mkdir -p build && cp .env* build/ && yarn copy-client && yarn compile",
    "dev": "concurrently --kill-others npm:compile-watch npm:nodemon",
    "build": "yarn clean && yarn compile && yarn copy-client",
    "start": "cd build && node -r --enable-source-maps index.js",
    "lint": "eslint . --ext .ts",
    "clean": "rm -rf build",
    "compile": "tsc -sourcemap",
    "compile-watch": "tsc --sourcemap --watch",
    "copy-client": "cp -r ../client/dist build/public",
    "nodemon": "cd build && nodemon -r --enable-source-maps -q index.js"
  },
  "dependencies": {
    "@types/cors": "^2.8.12",
    "@types/express": "5.0.6",
    "@types/node": "^17.0.23",
    "commander": "15.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "5.2.1",
    "winston": "^3.3.3"
  },
  "devDependencies": {
    "@types/jest": "^29.2.0",
    "@typescript-eslint/eslint-plugin": "^5.21.0",
    "@typescript-eslint/parser": "^5.21.0",
    "ast-types": "^0.14.2",
    "astring": "^1.8.1",
    "concurrently": "^7.1.0",
    "eslint": "^8.14.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-prettier": "^4.2.1",
    "jest": "^27.3.1",
    "nodemon": "^2.0.15",
    "prettier": "^2.7.1",
    "typescript": "^4.6.3"
  }
}
